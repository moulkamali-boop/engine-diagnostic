<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <title>تشخيص المحرك - اختبار الأذونات</title>
  <style>
    body { background: #0a0a0a; color: #eee; font-family: Arial; text-align: center; padding: 20px; }
    .btn { background: #ffd700; color: #1a1a1a; border: none; padding: 12px; border-radius: 30px; margin: 5px; width: 80%; cursor: pointer; }
    .status { background: #1a1a1a; padding: 10px; border-radius: 12px; margin: 10px; }
  </style>
</head>
<body>
  <h1>🔧 تشخيص المحرك</h1>
  <div id="status" class="status">⏳ جاري طلب الأذونات...</div>
  <div id="controls" style="display:none;">
    <button id="micBtn" class="btn">🎤 تسجيل الصوت (10 ثوانٍ)</button>
    <button id="camBtn" class="btn">📸 تصوير العادم</button>
    <button id="diagBtn" class="btn">🔍 شخص الآن</button>
    <button id="subBtn" class="btn" style="background:#ff6600;">🔒 الاشتراك ($20/شهر)</button>
  </div>
  <div id="result" style="margin-top:20px;"></div>

  <script>
    let audioBlob = null;
    let imageData = null;
    let freeCount = parseInt(localStorage.getItem('freeDiag')) || 0;

    async function requestPermissions() {
      try {
        // طلب الميكروفون
        const audio = await navigator.mediaDevices.getUserMedia({ audio: true });
        audio.getTracks().forEach(t => t.stop());
        
        // طلب الكاميرا
        const video = await navigator.mediaDevices.getUserMedia({ video: true });
        video.getTracks().forEach(t => t.stop());
        
        document.getElementById('status').innerHTML = '✅ الأذونات ممنوحة. يمكنك بدء التشخيص.';
        document.getElementById('controls').style.display = 'block';
      } catch(err) {
        document.getElementById('status').innerHTML = '❌ لم يتم منح الأذونات. يرجى السماح للكاميرا والميكروفون ثم تحديث الصفحة.';
      }
    }

    async function recordSound() {
      const btn = document.getElementById('micBtn');
      btn.disabled = true;
      btn.textContent = '🎤 جاري التسجيل...';
      try {
        const stream = await navigator.mediaDevices.getUserMedia({ audio: true });
        const recorder = new MediaRecorder(stream);
        const chunks = [];
        recorder.ondataavailable = e => chunks.push(e.data);
        recorder.onstop = () => {
          audioBlob = new Blob(chunks, { type: 'audio/wav' });
          btn.textContent = '✅ تم التسجيل';
          stream.getTracks().forEach(t => t.stop());
        };
        recorder.start();
        setTimeout(() => recorder.stop(), 10000);
      } catch(e) {
        btn.textContent = '❌ فشل التسجيل';
        setTimeout(() => btn.textContent = '🎤 تسجيل الصوت', 2000);
      }
    }

    async function takePhoto() {
      const btn = document.getElementById('camBtn');
      btn.disabled = true;
      btn.textContent = '📸 جاري التصوير...';
      try {
        const stream = await navigator.mediaDevices.getUserMedia({ video: true });
        const video = document.createElement('video');
        video.srcObject = stream;
        await video.play();
        setTimeout(() => {
          const canvas = document.createElement('canvas');
          canvas.width = video.videoWidth;
          canvas.height = video.videoHeight;
          canvas.getContext('2d').drawImage(video, 0, 0);
          imageData = canvas.toDataURL('image/jpeg', 0.8);
          btn.textContent = '✅ تم التصوير';
          stream.getTracks().forEach(t => t.stop());
        }, 1000);
      } catch(e) {
        btn.textContent = '❌ فشل التصوير';
        setTimeout(() => btn.textContent = '📸 تصوير العادم', 2000);
      }
    }

    function diagnose() {
      if(freeCount >= 3) {
        document.getElementById('result').innerHTML = '⚠️ استنفذت التشخيصات المجانية. اشترك للمتابعة.';
        return;
      }
      if(!audioBlob || !imageData) {
        document.getElementById('result').innerHTML = '⚠️ يرجى تسجيل الصوت وتصوير العادم أولاً.';
        return;
      }
      freeCount++;
      localStorage.setItem('freeDiag', freeCount);
      document.getElementById('result').innerHTML = '✅ المحرك سليم (تشخيص أولي). يرجى الاشتراك للتفاصيل الدقيقة.';
      if(freeCount >= 3) document.getElementById('subBtn').style.display = 'block';
    }

    function subscribe() {
      window.location.href = "https://ai-moto-maintenance.lemonsqueezy.com/checkout/buy/c3abadc2-c6cc-459e-a106-de43d4f2d3f0";
    }

    document.getElementById('micBtn').onclick = recordSound;
    document.getElementById('camBtn').onclick = takePhoto;
    document.getElementById('diagBtn').onclick = diagnose;
    document.getElementById('subBtn').onclick = subscribe;

    requestPermissions();
  </script>
</body>
</html>