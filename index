function changeLang(lang){state.lang=lang;localStorage.setItem('auto_lang',lang);applyTranslations();if(document.getElementById('lab-ui').style.display==='block')openLab(state.currentDevice);}
function initClock(){let tick=()=>{let now=new Date();document.getElementById('date').textContent=`${now.getDate().toString().padStart(2,'0')}/${(now.getMonth()+1).toString().padStart(2,'0')}/${now.getFullYear()}`;document.getElementById('clock').textContent=now.toLocaleTimeString('en-GB');};tick();setInterval(tick,1000);}
function initGeo(){let locationSpan=document.getElementById('location');if(!navigator.geolocation){locationSpan.textContent='❌ Not supported';return;}navigator.geolocation.getCurrentPosition((p)=>{locationSpan.textContent=`${p.coords.latitude.toFixed(4)}, ${p.coords.longitude.toFixed(4)}`;},()=>{locationSpan.textContent='❌ Denied';});}
function initQR(){new QRCode(document.getElementById('qr-container'),{text:window.location.href,width:50,height:50});}
function openLab(device){
    let credits = getCredits();
    if(credits <= 0 && !state.isAdmin){ showToast("⚠️ رصيدك انتهى. اشترِ تشخيصات جديدة."); return; }
    if(!checkLimit()) return;
    state.currentDevice=device;state.reportLines=[];state.finalDiagnosis='';
    document.getElementById('home-grid').style.display='none';
    document.getElementById('lab-ui').style.display='block';
    document.getElementById('lab-device-name').textContent=t(device);
    document.getElementById('live-report').innerHTML=t('waiting');
    document.getElementById('monitor-area').innerHTML=`<div style="padding:20px;color:#94a3b8">🔌 ${t('activate')}</div>`;
    for(let s in state.sensorStatus) if(state.sensorStatus[s]) stopSensor(s);
    setMode('quick');
}
function closeLab(){ for(let s in state.sensorStatus) if(state.sensorStatus[s]) stopSensor(s); document.getElementById('home-grid').style.display='grid'; document.getElementById('lab-ui').style.display='none'; if(state.globalTimerInterval) clearInterval(state.globalTimerInterval); }

initClock();initGeo();initQR();buildLangSelect();let savedLang=localStorage.getItem('auto_lang');if(savedLang)state.lang=savedLang;document.getElementById('lang-select').value=state.lang;document.getElementById('device-uid').textContent=state.deviceID;applyTranslations();updateCreditsDisplay();
document.getElementById('code-input').addEventListener('change',function(e){if(e.target.value.toUpperCase()==='MOULOUD2026'){showToast("✅ Code valid! Admin activated");if(!state.isAdmin){state.isAdmin=true;localStorage.setItem('auto_isAdmin',true);updateSubUI();updateCreditsDisplay();showToast(t('admin_on'));}}else{showToast("❌ Invalid code");}});
</script>
</body>
</html>