<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <title>تشخيص المحرك - نسخة مبسطة</title>
  <link rel="stylesheet" href="style.css">
</head>
<body>
  <div class="container">
    <h1>🔧 تشخيص المحرك</h1>
    <div class="counter" id="counter">🔓 المجانية: 3/3</div>
    
    <div class="lang">
      <button data-lang="ar">🇸🇦 عربي</button>
      <button data-lang="en">🇬🇧 English</button>
    </div>

    <button id="start-diagnose" class="btn">🔍 ابدأ التشخيص</button>

    <div id="step1" class="hidden steps">
      <button id="mic-btn" class="btn">🎤 تسجيل الصوت (10 ثوانٍ)</button>
      <button id="photo-btn" class="btn">📸 تصوير العادم</button>
      <button id="diagnose-btn" class="btn">🔍 شخص الآن</button>
    </div>

    <div id="result-card" class="result hidden">
      <h3 id="result-title">النتيجة</h3>
      <div id="result-text"></div>
      <button id="download-pdf" class="btn">📄 تحميل PDF</button>
      <button id="subscribe-btn" class="btn subscribe hidden">🔒 الاشتراك ($20/شهر)</button>
    </div>
  </div>
  <script src="script.js"></script>
</body>
</html>