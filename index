async function startCamera(){
    if(state.sensorStatus.camera) return;
    // نضيف الفيديو داخل monitor-area دون مسح المحتوى الحالي
    const monitorDiv = document.getElementById('monitor-area');
    const video = document.createElement('video');
    video.id = 'cameraVideo';
    video.autoplay = true;
    video.playsInline = true;
    video.muted = true;
    video.style.width = '100%';
    video.style.height = '100%';
    video.style.objectFit = 'cover';
    monitorDiv.appendChild(video);
    try{
        const stream=await navigator.mediaDevices.getUserMedia({video:{facingMode:'environment'}});
        video.srcObject=stream; await video.play();
        state.currentStreams.camera=stream; state.sensorStatus.camera=true;
        document.getElementById('btn-cam').classList.add('active');
    }catch(e){ showToast(t('camera_error')); }
}
async function startMicrophone(){
    if(state.sensorStatus.microphone) return;
    const monitorDiv = document.getElementById('monitor-area');
    const canvas = document.createElement('canvas');
    canvas.id = 'micCanvas';
    canvas.width = monitorDiv.clientWidth;
    canvas.height = 200;
    canvas.style.width = '100%';
    canvas.style.height = '200px';
    canvas.style.background = '#000';
    monitorDiv.appendChild(canvas);
    try{
        const stream=await navigator.mediaDevices.getUserMedia({audio:true});
        state.currentStreams.microphone=stream;
        const audioCtx=new AudioContext(); await audioCtx.resume();
        const source=audioCtx.createMediaStreamSource(stream);
        const analyser=audioCtx.createAnalyser();
        analyser.fftSize=256;
        source.connect(analyser);
        const dataArray=new Uint8Array(analyser.frequencyBinCount);
        const ctx=canvas.getContext('2d');
        function drawWave(){
            if(!state.sensorStatus.microphone) return;
            analyser.getByteFrequencyData(dataArray);
            ctx.clearRect(0,0,canvas.width,canvas.height);
            ctx.beginPath(); ctx.strokeStyle='#f5b81b'; ctx.lineWidth=2;
            for(let i=0;i<canvas.width;i+=5){
                let idx=Math.floor(i/canvas.width*dataArray.length);
                let val=dataArray[idx]/255;
                let y=canvas.height/2+(val*canvas.height/2)*(Math.sin(i*0.05)+0.5);
                if(i===0) ctx.moveTo(i,y); else ctx.lineTo(i,y);
            }
            ctx.stroke(); requestAnimationFrame(drawWave);
        }
        drawWave();
        state.sensorStatus.microphone=true;
        document.getElementById('btn-mic').classList.add('active');
    }catch(e){ showToast(t('mic_error')); }
}
function startVibration(){
    if(state.sensorStatus.vibration) return;
    if(!window.DeviceMotionEvent){showToast(t('vibration_not_supported'));return;}
    const monitorDiv = document.getElementById('monitor-area');
    const canvas = document.createElement('canvas');
    canvas.id = 'vibCanvas';
    canvas.width = monitorDiv.clientWidth;
    canvas.height = 200;
    canvas.style.width = '100%';
    canvas.style.height = '200px';
    canvas.style.background = '#000';
    monitorDiv.appendChild(canvas);
    const ctx=canvas.getContext('2d');
    let lastX=0,lastY=0,lastZ=0;
    const handler=(e)=>{
        if(!state.sensorStatus.vibration) return;
        const acc=e.accelerationIncludingGravity;
        if(acc){
            const intensity=Math.min(100,(Math.abs(acc.x-lastX)+Math.abs(acc.y-lastY)+Math.abs(acc.z-lastZ))*15);
            lastX=acc.x; lastY=acc.y; lastZ=acc.z;
            ctx.clearRect(0,0,canvas.width,canvas.height);
            ctx.fillStyle='#f59e0b';
            ctx.fillRect(0,canvas.height-(intensity*canvas.height/100),canvas.width,intensity*canvas.height/100);
            ctx.fillStyle='#fff'; ctx.font='12px monospace';
            ctx.fillText(`${t('vibration_label')||'Vibration'}: ${intensity.toFixed(0)}%`,10,20);
        }
    };
    window.addEventListener('devicemotion',handler);
    state.vibrationHandler=handler;
    state.sensorStatus.vibration=true;
    document.getElementById('btn-vib').classList.add('active');
    state.currentIntervals.vibration=setInterval(()=>{},100);
}
function startTemperature(){
    if(state.sensorStatus.temperature) return;
    const monitorDiv = document.getElementById('monitor-area');
    const tempDiv = document.createElement('div');
    tempDiv.style.padding = '30px';
    tempDiv.style.textAlign = 'center';
    tempDiv.innerHTML = `<span style="font-size:2rem;font-weight:700;" id="tempValue">--°C</span><div>${t('temp_estimate')||'Engine Temperature Estimate'}</div>`;
    monitorDiv.appendChild(tempDiv);
    let temp=28+Math.random()*10;
    const updateTemp=()=>{
        if(!state.sensorStatus.temperature) return;
        temp+=(Math.random()-0.5)*0.3;
        temp=Math.min(48,Math.max(22,temp));
        const el=document.getElementById('tempValue');
        if(el) el.textContent=`${temp.toFixed(1)}°C`;
    };
    updateTemp();
    state.currentIntervals.temperature=setInterval(updateTemp,800);
    state.sensorStatus.temperature=true;
    document.getElementById('btn-temp').classList.add('active');
}
function stopSensor(sensorType){
    if(sensorType==='camera' && state.currentStreams.camera){
        state.currentStreams.camera.getTracks().forEach(t=>t.stop()); state.currentStreams.camera=null;
        state.sensorStatus.camera=false; document.getElementById('btn-cam').classList.remove('active');
        const vid=document.getElementById('cameraVideo'); if(vid) vid.remove();
    }
    if(sensorType==='microphone' && state.currentStreams.microphone){
        state.currentStreams.microphone.getTracks().forEach(t=>t.stop()); state.currentStreams.microphone=null;
        state.sensorStatus.microphone=false; document.getElementById('btn-mic').classList.remove('active');
        const canv=document.getElementById('micCanvas'); if(canv) canv.remove();
    }
    if(sensorType==='vibration'){
        if(state.vibrationHandler) window.removeEventListener('devicemotion',state.vibrationHandler);
        if(state.currentIntervals.vibration) clearInterval(state.currentIntervals.vibration);
        state.sensorStatus.vibration=false; document.getElementById('btn-vib').classList.remove('active');
        const canv=document.getElementById('vibCanvas'); if(canv) canv.remove();
    }
    if(sensorType==='temperature'){
        if(state.currentIntervals.temperature) clearInterval(state.currentIntervals.temperature);
        state.sensorStatus.temperature=false; document.getElementById('btn-temp').classList.remove('active');
        const tempDiv=document.querySelector('#monitor-area > div:has(#tempValue)'); if(tempDiv) tempDiv.remove();
    }
}
