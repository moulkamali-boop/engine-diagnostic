    }
    const langMap={en:'en-US',fr:'fr-FR',es:'es-ES',de:'de-DE',it:'it-IT',pt:'pt-PT',ru:'ru-RU',ko:'ko-KR',tr:'tr-TR',nl:'nl-NL',pl:'pl-PL',id:'id-ID',sw:'sw-KE',vi:'vi-VN',el:'el-GR',cs:'cs-CZ',uk:'uk-UA',ro:'ro-RO',hu:'hu-HU',sv:'sv-SE',da:'da-DK',fi:'fi-FI',no:'nb-NO',sk:'sk-SK',bg:'bg-BG',hr:'hr-HR',lt:'lt-LT',lv:'lv-LV',et:'et-EE',sl:'sl-SI',ms:'ms-MY'};
