// ==================== DIAGNOSTIC (نسخة app_v2_good.html مع إضافة الرصيد وشريط التقدم) ====================
let integratedStep=0;
async function startIntegratedDiagnosis(){
    if(Object.values(state.sensorStatus).some(s=>s===true)){showToast("Stop current sensors first");return;}
    if(!checkLimit()) return;
    let credits = getCredits();
    if(credits <= 0 && !state.isAdmin){ showToast("⚠️ رصيدك انتهى. اشترِ تشخيصات جديدة."); return; }
    integratedStep=0;
    document.getElementById('stepIndicator').classList.remove('hidden');
    // شريط تقدم عام 120 ثانية
    const monitorDiv = document.getElementById('monitor-area');
    const progDiv = document.createElement('div');
    progDiv.className = 'progress-bar-container';
    progDiv.innerHTML = `<div class="progress-fill" id="timeProgress"></div><div class="timer-text" id="timerText">⏳ جاري التشخيص 120 ث</div>`;
    monitorDiv.appendChild(progDiv);
    state.globalTimerStart = Date.now();
    state.globalTimerInterval = setInterval(() => {
        let elapsed = (Date.now() - state.globalTimerStart) / 1000;
        let remain = Math.max(0, 120 - elapsed);
        let pct = (elapsed / 120) * 100;
        let pbar = document.getElementById('timeProgress');
        let ttext = document.getElementById('timerText');
        if(pbar) pbar.style.width = `${Math.min(100,pct)}%`;
        if(ttext) ttext.innerText = `⏳ جاري التشخيص ${Math.ceil(remain)} ث`;
        if(remain <= 0) {
            clearInterval(state.globalTimerInterval);
            if(pbar) pbar.style.width = '100%';
            if(ttext) ttext.innerText = 'اكتمل جمع البيانات';
        }
    }, 1000);
    await runIntegratedStep();
}
async function runIntegratedStep(){
    const steps=[
        {name:'camera', msg:t('step_camera')||'📷 Step 1/4: Point camera at engine', action:captureCamera},
        {name:'microphone', msg:t('step_mic')||'🎙️ Step 2/4: Record engine sound (3 sec)', action:captureMic},
        {name:'vibration', msg:t('step_vib')||'📳 Step 3/4: Place phone on engine (5 sec)', action:captureVibration},
        {name:'temperature', msg:t('step_temp')||'🌡️ Step 4/4: Measuring temperature...', action:captureTemp}
    ];
    if(integratedStep>=steps.length){ await finalizeIntegratedDiagnosis(); return; }
    const step=steps[integratedStep];
    document.getElementById('stepIndicator').innerHTML=step.msg;
    await step.action();
    integratedStep++;
    await runIntegratedStep();
}
async function captureCamera(){ return new Promise(resolve=>setTimeout(resolve,2000)); }
async function captureMic(){ return new Promise(resolve=>setTimeout(resolve,3000)); }
async function captureVibration(){ return new Promise(resolve=>setTimeout(resolve,4000)); }
async function captureTemp(){ return new Promise(resolve=>setTimeout(resolve,3000)); }
async function finalizeIntegratedDiagnosis(){
    if(state.globalTimerInterval) clearInterval(state.globalTimerInterval);
    // إزالة شريط التقدم
    const prog = document.querySelector('.progress-bar-container');
    if(prog) prog.remove();
    // التشخيص العشوائي (مؤقتاً) – كما في الأصل
    let diagnosis=t('normal'); let solution="🔧 "+t('normal');
    if(Math.random()>0.5){ diagnosis=t('fault_vibration'); solution="🔧 "+t('fault_solution'); }
    const report=`🧠 Integrated Report:\n\nDiagnosis: ${diagnosis}\n${solution}`;
    document.getElementById('monitor-area').innerHTML=`<div style="padding:20px;">${report}</div>`;
    document.getElementById('stepIndicator').classList.add('hidden');
    state.reportLines.push(`🧠 ${diagnosis}`); state.reportLines.push(solution);
    state.finalDiagnosis=diagnosis;
    document.getElementById('live-report').innerHTML=state.reportLines.join('\n');
    saveToHistory(diagnosis,solution);
    useCredit(); // خصم رصيد
    incrementUsage(); // للتوافق القديم
}
